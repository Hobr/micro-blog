---
import BlogIndexPage from "../../../views/BlogIndexPage.astro";
import { buildAlternateLinks } from "../../../i18n/config";
import { getDictionary } from "../../../i18n/dictionary";
import {
    assertSecondaryLocale,
    getSecondaryLocaleStaticPaths,
} from "../../../i18n/static-paths";
import { getAllPosts, getAllTags } from "../../../lib/posts";

export function getStaticPaths() {
    return getSecondaryLocaleStaticPaths();
}

const { locale } = Astro.props as { locale: string };
const secondaryLocale = assertSecondaryLocale(locale);
const dictionary = getDictionary(secondaryLocale);
const [posts, tags] = await Promise.all([getAllPosts(), getAllTags()]);
const alternateLinks = buildAlternateLinks(Astro.url.pathname);
---

<BlogIndexPage
    locale={secondaryLocale}
    dictionary={dictionary}
    posts={posts}
    tags={tags}
    alternateLinks={alternateLinks}
/>
