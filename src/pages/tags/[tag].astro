---
import PostList from "../../components/PostList.astro";
import TerminalWindow from "../../components/TerminalWindow.astro";
import Layout from "../../layouts/Layout.astro";
import { getAllTags, getPostsByTag } from "../../lib/posts";

export async function getStaticPaths() {
    return (await getAllTags()).map((tag) => ({
        params: { tag },
        props: { tag },
    }));
}

const { tag } = Astro.props as { tag: string };
const posts = await getPostsByTag(tag);
---

<Layout
    title={`HORB.SITE / #${tag}`}
    description={`Posts tagged ${tag} on HORB.SITE.`}
>
    <main class="page-shell">
        <section class="page-intro">
            <p class="page-eyebrow">tag view</p>
            <h1 class="page-title">#{tag}</h1>
            <p class="page-copy">
                Filtered log view for one topic. Go back to <a href="/blog"
                    >all posts</a
                >
                when you want the full stream.
            </p>
        </section>

        <TerminalWindow title="TAG RESULTS" subtitle={`grep -r ${tag} ./posts`}>
            <PostList
                posts={posts}
                emptyMessage="No posts found for this tag."
            />
        </TerminalWindow>
    </main>
</Layout>
