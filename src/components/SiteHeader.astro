---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import ThemeSwitcher from "./ThemeSwitcher.astro";
import type { AlternateLink, Locale } from "../i18n/config";
import type { SiteDictionary } from "../i18n/dictionary";
import { stripLocaleFromPathname, toLocalePath } from "../i18n/config";

interface Props {
    locale: Locale;
    dictionary: SiteDictionary;
    alternateLinks: AlternateLink[];
}

const { locale, dictionary, alternateLinks } = Astro.props;
const { pathnameWithoutLocale } = stripLocaleFromPathname(Astro.url.pathname);

const links = [
    {
        href: toLocalePath(locale, "/"),
        label: dictionary.nav.home,
        key: "home",
    },
    {
        href: toLocalePath(locale, "/blog"),
        label: dictionary.nav.blog,
        key: "blog",
    },
    {
        href: toLocalePath(locale, "/archive"),
        label: dictionary.nav.archive,
        key: "archive",
    },
];

const activeSection =
    pathnameWithoutLocale === "/"
        ? "home"
        : pathnameWithoutLocale === "/blog" ||
            pathnameWithoutLocale.startsWith("/blog/") ||
            pathnameWithoutLocale === "/tags" ||
            pathnameWithoutLocale.startsWith("/tags/")
          ? "blog"
          : pathnameWithoutLocale === "/archive" ||
              pathnameWithoutLocale.startsWith("/archive/")
            ? "archive"
            : null;
---

<header class="site-header" lang={locale}>
    <div class="site-header__inner">
        <div class="site-brand">
            <a class="site-brand__name" href={toLocalePath(locale, "/")}>
                {dictionary.brand.name}
            </a>
            <p class="site-brand__meta">{dictionary.brand.meta}</p>
        </div>
        <div class="site-header__controls">
            <nav class="site-nav" aria-label={dictionary.nav.primaryLabel}>
                {
                    links.map((link) => (
                        <a
                            class:list={[
                                "site-nav__link",
                                { "is-active": activeSection === link.key },
                            ]}
                            href={link.href}
                            aria-current={
                                activeSection === link.key ? "page" : undefined
                            }
                        >
                            <span class="site-nav__prompt" aria-hidden="true">
                                $
                            </span>
                            <span>{link.label}</span>
                        </a>
                    ))
                }
            </nav>
            <div class="site-header__meta">
                <ThemeSwitcher label={dictionary.brand.themeLabel} />
                <LanguageSwitcher
                    currentLocale={locale}
                    label={dictionary.brand.switcherLabel}
                    alternateLinks={alternateLinks}
                />
            </div>
        </div>
    </div>
</header>
