---
import type { Locale } from "../i18n/config";
import type { SiteDictionary } from "../i18n/dictionary";
import { stripLocaleFromPathname, toLocalePath } from "../i18n/config";

interface Props {
    locale: Locale;
    dictionary: SiteDictionary;
}

const { locale, dictionary } = Astro.props;
const { pathnameWithoutLocale } = stripLocaleFromPathname(Astro.url.pathname);

const links = [
    {
        href: toLocalePath(locale, "/"),
        label: dictionary.nav.home,
        key: "home",
    },
    {
        href: toLocalePath(locale, "/blog"),
        label: dictionary.nav.blog,
        key: "blog",
    },
    {
        href: toLocalePath(locale, "/archive"),
        label: dictionary.nav.archive,
        key: "archive",
    },
];

const activeSection =
    pathnameWithoutLocale === "/"
        ? "home"
        : pathnameWithoutLocale === "/blog" ||
            pathnameWithoutLocale.startsWith("/blog/") ||
            pathnameWithoutLocale === "/tags" ||
            pathnameWithoutLocale.startsWith("/tags/")
          ? "blog"
          : pathnameWithoutLocale === "/archive" ||
              pathnameWithoutLocale.startsWith("/archive/")
            ? "archive"
            : null;
---

<header class="site-header" lang={locale}>
    <div class="site-header__inner">
        <div class="site-brand">
            <a class="site-brand__name" href={toLocalePath(locale, "/")}>
                {dictionary.brand.name}
            </a>
            <p class="site-brand__meta">{dictionary.brand.meta}</p>
        </div>
        <nav
            class="terminal-menu site-nav"
            aria-label={dictionary.nav.primaryLabel}
        >
            <ul>
                {
                    links.map((link) => (
                        <li>
                            <a
                                class:list={[
                                    "site-nav__link",
                                    {
                                        active: activeSection === link.key,
                                    },
                                ]}
                                href={link.href}
                                aria-current={
                                    activeSection === link.key
                                        ? "page"
                                        : undefined
                                }
                            >
                                {link.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
    </div>
</header>
