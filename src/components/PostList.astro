---
import type { Locale } from "../i18n/config";
import { toLocalePath } from "../i18n/config";
import type { BlogPost } from "../lib/posts";

interface Props {
    posts: BlogPost[];
    locale: Locale;
    emptyMessage?: string;
}

const { posts, locale, emptyMessage = "No posts found." } = Astro.props;
---

{
    posts.length > 0 ? (
        <ul>
            {posts.map((post) => (
                <li>
                    <a href={toLocalePath(locale, `/blog/${post.slug}`)}>
                        {post.title}
                    </a>
                    <small> / {post.dateLabel}</small>
                </li>
            ))}
        </ul>
    ) : (
        <p>{emptyMessage}</p>
    )
}
