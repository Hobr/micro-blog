---
import type { Locale } from "../i18n/config";
import { toLocalePath } from "../i18n/config";
import type { BlogPost } from "../lib/posts";

interface Props {
    locale: Locale;
    previous?: BlogPost;
    next?: BlogPost;
    previousLabel: string;
    nextLabel: string;
    emptyPreviousLabel: string;
    emptyNextLabel: string;
}

const {
    locale,
    previous,
    next,
    previousLabel,
    nextLabel,
    emptyPreviousLabel,
    emptyNextLabel,
} = Astro.props;
---

<div class="post-pagination">
    {
        previous ? (
            <p>
                <small>{previousLabel}</small>{" "}
                <a href={toLocalePath(locale, `/blog/${previous.slug}`)}>
                    {previous.title}
                </a>
            </p>
        ) : (
            <p>
                <small>{previousLabel}</small>{" "}
                <strong>{emptyPreviousLabel}</strong>
            </p>
        )
    }
    {
        next ? (
            <p>
                <small>{nextLabel}</small>{" "}
                <a href={toLocalePath(locale, `/blog/${next.slug}`)}>
                    {next.title}
                </a>
            </p>
        ) : (
            <p>
                <small>{nextLabel}</small> <strong>{emptyNextLabel}</strong>
            </p>
        )
    }
</div>
