---
import type { Locale } from "../i18n/config";
import { toLocalePath } from "../i18n/config";

interface Props {
    tags: string[];
    locale: Locale;
    label: string;
}

const { tags, locale, label } = Astro.props;
---

<ul class="tag-list" aria-label={label}>
    {
        tags.map((tag) => (
            <li>
                <a
                    class="tag-list__link"
                    href={toLocalePath(
                        locale,
                        `/tags/${encodeURIComponent(tag)}`,
                    )}
                >
                    #{tag}
                </a>
            </li>
        ))
    }
</ul>
