---
import {
    THEME_STORAGE_KEY,
    defaultThemeId,
    themes,
    themeIds,
} from "../data/themes";

interface Props {
    label: string;
}

const { label } = Astro.props;
---

<label class="theme-switcher">
    <span class="theme-switcher__label">{label}</span>
    <select
        class="theme-switcher__select"
        name="theme"
        aria-label={label}
        data-theme-select
    >
        {
            themes.map((theme) => (
                <option value={theme.id} selected={theme.id === defaultThemeId}>
                    {theme.label}
                </option>
            ))
        }
    </select>
</label>

<script
    is:inline
    define:vars={{
        storageKey: THEME_STORAGE_KEY,
        fallbackTheme: defaultThemeId,
        knownThemes: themeIds,
    }}
>
    const applyTheme = (themeId) => {
        document.documentElement.dataset.theme = themeId;
        document.querySelectorAll("[data-theme-select]").forEach((select) => {
            if (select instanceof HTMLSelectElement) {
                select.value = themeId;
            }
        });
    };

    const readTheme = () => {
        try {
            const stored = window.localStorage.getItem(storageKey);
            return stored && knownThemes.includes(stored)
                ? stored
                : fallbackTheme;
        } catch {
            return fallbackTheme;
        }
    };

    const syncTheme = () => {
        applyTheme(readTheme());
    };

    syncTheme();

    document.addEventListener("astro:before-swap", (event) => {
        if (
            !("newDocument" in event) ||
            !(event.newDocument instanceof Document)
        ) {
            return;
        }

        event.newDocument.documentElement.dataset.theme = readTheme();
    });

    document.addEventListener("astro:after-swap", syncTheme);
    document.addEventListener("astro:page-load", syncTheme);

    document.addEventListener("change", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLSelectElement)) {
            return;
        }

        if (!target.matches("[data-theme-select]")) {
            return;
        }

        const nextTheme = knownThemes.includes(target.value)
            ? target.value
            : fallbackTheme;

        applyTheme(nextTheme);

        try {
            window.localStorage.setItem(storageKey, nextTheme);
        } catch {}
    });
</script>
