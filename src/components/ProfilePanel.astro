---
import type { ProfileData } from "../data/profile";

interface Props {
    profile: ProfileData;
}

const { profile } = Astro.props;
---

<section>
    <img src={profile.avatar} alt={profile.avatarAlt} width="80" height="80" />
    <p>{profile.eyebrow}</p>
    <h2>{profile.name}</h2>
    <p>{profile.role}</p>
    <p>{profile.bio}</p>
    <p>
        <strong>{profile.stackLabel}:</strong>
        {profile.stack.join(", ")}
    </p>
</section>
