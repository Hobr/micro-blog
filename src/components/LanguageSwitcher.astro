---
import type { AlternateLink, Locale } from "../i18n/config";

interface Props {
    currentLocale: Locale;
    label: string;
    shortLabel: string;
    alternateLinks: AlternateLink[];
}

const { currentLocale, label, shortLabel, alternateLinks } = Astro.props;
---

<nav class="language-switcher" aria-label={label}>
    <span class="language-switcher__label">{shortLabel}</span>
    <ul>
        {
            alternateLinks.map((link) => (
                <li>
                    <a
                        class:list={[{ active: link.locale === currentLocale }]}
                        href={link.href}
                        hreflang={link.lang}
                        lang={link.lang}
                        aria-current={
                            link.locale === currentLocale ? "page" : undefined
                        }
                    >
                        {link.label}
                    </a>
                </li>
            ))
        }
    </ul>
</nav>
