---
interface Props {
    title: string;
    subtitle?: string;
    chromeLang?: string;
}

const { title, subtitle, chromeLang } = Astro.props;
---

<section class="terminal-window terminal-block">
    <header
        class="terminal-window__header terminal-block__header"
        lang={chromeLang}
    >
        <p class="terminal-window__title terminal-block__title">
            <span class="terminal-window__prompt" aria-hidden="true">$</span>
            <span>{title}</span>
        </p>
        {
            subtitle && (
                <p class="terminal-window__subtitle terminal-block__subtitle">
                    {subtitle}
                </p>
            )
        }
    </header>
    <div class="terminal-window__body terminal-block__body">
        <slot />
    </div>
</section>
