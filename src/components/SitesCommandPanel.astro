---
import type { LocalizedSiteCommand } from "../data/sites";

interface Props {
    sites?: LocalizedSiteCommand[];
    label?: string;
}

const { sites = [], label = "Owned sites" } = Astro.props;
---

<ul class="command-list" aria-label={label}>
    {
        sites.map((site) => (
            <li>
                <a href={site.href}>
                    <span class="command-list__command">{site.command}</span>
                    <small>{site.name}</small>
                    <span class="command-list__arrow" aria-hidden="true">
                        -&gt;
                    </span>
                </a>
            </li>
        ))
    }
</ul>
