---
import PostList from "../components/PostList.astro";
import SitesCommandPanel from "../components/SitesCommandPanel.astro";
import Layout from "../layouts/Layout.astro";
import type { LocalizedSiteCommand } from "../data/sites";
import type { AlternateLink, Locale } from "../i18n/config";
import { toLocalePath } from "../i18n/config";
import type { SiteDictionary } from "../i18n/dictionary";
import type { BlogPost } from "../lib/posts";

interface Props {
    locale: Locale;
    dictionary: SiteDictionary;
    posts: BlogPost[];
    tags: string[];
    alternateLinks: AlternateLink[];
}

const { locale, dictionary, posts, tags, alternateLinks } = Astro.props;
const browseCommands: LocalizedSiteCommand[] = [
    {
        command: dictionary.blogIndex.openArchive,
        name: dictionary.nav.archive,
        href: toLocalePath(locale, "/archive"),
    },
    ...tags.map((tag) => ({
        command: dictionary.blogIndex.openTag(tag),
        name: `#${tag}`,
        href: toLocalePath(locale, `/tags/${encodeURIComponent(tag)}`),
    })),
];
---

<Layout
    title={dictionary.blogIndex.metaTitle}
    locale={locale}
    dictionary={dictionary}
    alternateLinks={alternateLinks}
>
    <main class="page-shell index-page" id="main-content">
        <section class="terminal-panel post-index-panel">
            <div class="section-heading">
                <p class="terminal-prompt">
                    <span aria-hidden="true">$</span>
                    {dictionary.blogIndex.listSubtitle}
                </p>
            </div>
            <PostList
                posts={posts}
                locale={locale}
                emptyMessage={dictionary.common.noPosts}
            />
        </section>

        <aside class="terminal-panel browse-panel">
            <p class="terminal-prompt">
                <span aria-hidden="true">$</span>
                {dictionary.blogIndex.navSubtitle}
            </p>
            <SitesCommandPanel
                sites={browseCommands}
                label={dictionary.blogIndex.navSubtitle}
            />
        </aside>
    </main>
</Layout>
