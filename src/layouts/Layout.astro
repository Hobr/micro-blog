---
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import SiteHeader from "../components/SiteHeader.astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import {
    THEME_STORAGE_KEY,
    defaultThemeId,
    getThemeStyles,
    themeIds,
} from "../data/themes";
import type { AlternateLink, Locale } from "../i18n/config";
import type { SiteDictionary } from "../i18n/dictionary";
import "../styles/global.css";

interface Props {
    title: string;
    description: string;
    locale: Locale;
    documentLang?: string;
    dictionary: SiteDictionary;
    alternateLinks: AlternateLink[];
    canonicalPath?: string;
}

const {
    title,
    description,
    locale,
    documentLang = locale,
    dictionary,
    alternateLinks,
    canonicalPath = Astro.url.pathname,
} = Astro.props;

const siteBase = Astro.site ?? Astro.url;
const canonical = new URL(canonicalPath, siteBase).href;
const themeStyles = getThemeStyles();
const themeBootstrapScript = `
(() => {
    const storageKey = ${JSON.stringify(THEME_STORAGE_KEY)};
    const fallbackTheme = ${JSON.stringify(defaultThemeId)};
    const knownThemes = new Set(${JSON.stringify(themeIds)});
    let nextTheme = fallbackTheme;

    try {
        const storedTheme = window.localStorage.getItem(storageKey);
        if (storedTheme && knownThemes.has(storedTheme)) {
            nextTheme = storedTheme;
        }
    } catch {}

    document.documentElement.dataset.theme = nextTheme;
})();
`;
---

<!doctype html>
<html lang={documentLang} data-theme={defaultThemeId}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link rel="canonical" href={canonical} />
        {
            alternateLinks.map((link) => (
                <link
                    rel="alternate"
                    hreflang={link.lang}
                    href={new URL(link.href, siteBase).href}
                />
            ))
        }
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <style is:inline set:html={themeStyles}></style>
        <script is:inline set:html={themeBootstrapScript} />
        <title>{title}</title>
    </head>
    <body class="terminal">
        <div class="site-shell">
            <SiteHeader locale={locale} dictionary={dictionary} />
            <slot />
            <footer class="site-footer" lang={locale}>
                <ThemeSwitcher label={dictionary.brand.themeLabel} />
                <LanguageSwitcher
                    currentLocale={locale}
                    label={dictionary.brand.switcherLabel}
                    alternateLinks={alternateLinks}
                />
            </footer>
        </div>
    </body>
</html>
