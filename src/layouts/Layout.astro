---
import { ClientRouter } from "astro:transitions";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import SiteHeader from "../components/SiteHeader.astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import {
    THEME_STORAGE_KEY,
    defaultThemeId,
    getThemeStyles,
    themeIds,
} from "../data/themes";
import type { AlternateLink, Locale } from "../i18n/config";
import type { SiteDictionary } from "../i18n/dictionary";
import "../styles/global.css";

interface Props {
    title: string;
    locale: Locale;
    documentLang?: string;
    dictionary: SiteDictionary;
    alternateLinks: AlternateLink[];
    canonicalPath?: string;
}

const {
    title,
    locale,
    documentLang = locale,
    dictionary,
    alternateLinks,
    canonicalPath = Astro.url.pathname,
} = Astro.props;

const siteBase = Astro.site ?? Astro.url;
const canonical = new URL(canonicalPath, siteBase).href;
const currentYear = new Date().getFullYear();
const siteDescription = `${dictionary.brand.name} personal blogs.`;
const themeStyles = getThemeStyles();
const pageTransition = {
    forwards: {
        old: [
            { name: "pageContentFadeOut", duration: "120ms", fillMode: "both" },
        ],
        new: [
            {
                name: "pageContentRiseIn",
                duration: "280ms",
                easing: "cubic-bezier(0.16, 1, 0.3, 1)",
                fillMode: "both",
            },
        ],
    },
    backwards: {
        old: [
            { name: "pageContentFadeOut", duration: "120ms", fillMode: "both" },
        ],
        new: [
            {
                name: "pageContentDropIn",
                duration: "280ms",
                easing: "cubic-bezier(0.16, 1, 0.3, 1)",
                fillMode: "both",
            },
        ],
    },
};
const themeBootstrapScript = `
(() => {
    const storageKey = ${JSON.stringify(THEME_STORAGE_KEY)};
    const fallbackTheme = ${JSON.stringify(defaultThemeId)};
    const knownThemes = new Set(${JSON.stringify(themeIds)});
    let nextTheme = window.matchMedia?.("(prefers-color-scheme: light)").matches
        ? "paper-light"
        : fallbackTheme;

    try {
        const storedTheme = window.localStorage.getItem(storageKey);
        if (storedTheme && knownThemes.has(storedTheme)) {
            nextTheme = storedTheme;
        }
    } catch {}

    document.documentElement.dataset.theme = nextTheme;
})();
`;
---

<!doctype html>
<html lang={documentLang} data-theme={defaultThemeId}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="theme-color" content="#0b0f0c" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link rel="canonical" href={canonical} />
        {
            alternateLinks.map((link) => (
                <link
                    rel="alternate"
                    hreflang={link.lang}
                    href={new URL(link.href, siteBase).href}
                />
            ))
        }
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={siteDescription} />
        <style is:inline set:html={themeStyles}></style>
        <script is:inline set:html={themeBootstrapScript} />
        <ClientRouter />
        <title>{title}</title>
    </head>
    <body>
        <div class="site-shell">
            <SiteHeader locale={locale} dictionary={dictionary} />
            <div
                class="page-transition-shell"
                transition:name="page-content"
                transition:animate={pageTransition}
            >
                <slot />
            </div>
            <footer
                class="site-footer"
                lang={locale}
                transition:name="site-footer"
                transition:animate="none"
            >
                <p class="site-footer__copyright">
                    <span aria-hidden="true">$</span>
                    <span
                        >{
                            `printf "© ${currentYear} ${dictionary.brand.name}"`
                        }</span
                    >
                </p>
                <div class="site-footer__controls">
                    <ThemeSwitcher label={dictionary.brand.themeLabel} />
                    <LanguageSwitcher
                        currentLocale={locale}
                        shortLabel={dictionary.brand.switcherLabel}
                        alternateLinks={alternateLinks}
                    />
                </div>
            </footer>
        </div>
    </body>
</html>
