---
import { ClientRouter } from "astro:transitions";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import SiteHeader from "../components/SiteHeader.astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import {
    THEME_STORAGE_KEY,
    defaultThemeId,
    getThemeStyles,
    themeIds,
} from "../data/themes";
import type { AlternateLink, Locale } from "../i18n/config";
import type { SiteDictionary } from "../i18n/dictionary";
import "../styles/global.css";

interface Props {
    title: string;
    description: string;
    locale: Locale;
    documentLang?: string;
    dictionary: SiteDictionary;
    alternateLinks: AlternateLink[];
    canonicalPath?: string;
}

const {
    title,
    description,
    locale,
    documentLang = locale,
    dictionary,
    alternateLinks,
    canonicalPath = Astro.url.pathname,
} = Astro.props;

const siteBase = Astro.site ?? Astro.url;
const canonical = new URL(canonicalPath, siteBase).href;
const currentYear = new Date().getFullYear();
const themeStyles = getThemeStyles();
const pageTransition = {
    forwards: {
        old: [
            {
                name: "pageContentFadeOut",
                duration: "140ms",
                easing: "cubic-bezier(0.55, 0, 1, 0.45)",
                fillMode: "both",
            },
            {
                name: "pageContentShiftUp",
                duration: "220ms",
                easing: "cubic-bezier(0.22, 1, 0.36, 1)",
                fillMode: "both",
            },
        ],
        new: [
            {
                name: "pageContentFadeIn",
                duration: "240ms",
                delay: "30ms",
                easing: "cubic-bezier(0.22, 1, 0.36, 1)",
                fillMode: "both",
            },
            {
                name: "pageContentRiseIn",
                duration: "240ms",
                easing: "cubic-bezier(0.22, 1, 0.36, 1)",
                fillMode: "both",
            },
        ],
    },
    backwards: {
        old: [
            {
                name: "pageContentFadeOut",
                duration: "140ms",
                easing: "cubic-bezier(0.55, 0, 1, 0.45)",
                fillMode: "both",
            },
            {
                name: "pageContentShiftDown",
                duration: "220ms",
                easing: "cubic-bezier(0.22, 1, 0.36, 1)",
                fillMode: "both",
            },
        ],
        new: [
            {
                name: "pageContentFadeIn",
                duration: "240ms",
                delay: "30ms",
                easing: "cubic-bezier(0.22, 1, 0.36, 1)",
                fillMode: "both",
            },
            {
                name: "pageContentDropIn",
                duration: "240ms",
                easing: "cubic-bezier(0.22, 1, 0.36, 1)",
                fillMode: "both",
            },
        ],
    },
};
const themeBootstrapScript = `
(() => {
    const storageKey = ${JSON.stringify(THEME_STORAGE_KEY)};
    const fallbackTheme = ${JSON.stringify(defaultThemeId)};
    const knownThemes = new Set(${JSON.stringify(themeIds)});
    let nextTheme = fallbackTheme;

    try {
        const storedTheme = window.localStorage.getItem(storageKey);
        if (storedTheme && knownThemes.has(storedTheme)) {
            nextTheme = storedTheme;
        }
    } catch {}

    document.documentElement.dataset.theme = nextTheme;
})();
`;
const footerDockScript = `
(() => {
    if (window.__footerDockInitialized) {
        return;
    }

    window.__footerDockInitialized = true;

    const root = document.documentElement;
    let resizeObserver;
    let observedFooter;

    const setFooterHeight = (footer) => {
        root.style.setProperty(
            "--site-footer-dock-height",
            \`\${Math.ceil(footer.getBoundingClientRect().height)}px\`,
        );
    };

    const syncFooterDock = () => {
        const footer = document.querySelector("[data-site-footer-dock]");
        if (!(footer instanceof HTMLElement)) {
            return;
        }

        setFooterHeight(footer);

        if (observedFooter === footer || typeof ResizeObserver === "undefined") {
            return;
        }

        resizeObserver?.disconnect();
        resizeObserver = new ResizeObserver(() => {
            setFooterHeight(footer);
        });
        resizeObserver.observe(footer);
        observedFooter = footer;
    };

    syncFooterDock();
    window.addEventListener("resize", syncFooterDock, { passive: true });
    document.addEventListener("astro:after-swap", syncFooterDock);
    document.addEventListener("astro:page-load", syncFooterDock);
})();
`;
---

<!doctype html>
<html lang={documentLang} data-theme={defaultThemeId}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link rel="canonical" href={canonical} />
        {
            alternateLinks.map((link) => (
                <link
                    rel="alternate"
                    hreflang={link.lang}
                    href={new URL(link.href, siteBase).href}
                />
            ))
        }
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <style is:inline set:html={themeStyles}></style>
        <script is:inline set:html={themeBootstrapScript} />
        <ClientRouter />
        <title>{title}</title>
    </head>
    <body class="terminal">
        <div class="site-shell">
            <SiteHeader locale={locale} dictionary={dictionary} />
            <div
                class="page-transition-shell"
                transition:name="page-content"
                transition:animate={pageTransition}
            >
                <slot />
            </div>
            <footer
                class="site-footer"
                lang={locale}
                data-site-footer-dock
                transition:name="site-footer"
                transition:animate="none"
            >
                <ThemeSwitcher label={dictionary.brand.themeLabel} />
                <p class="site-footer__copyright">
                    &copy; {currentYear}
                    {dictionary.brand.name}
                </p>
                <LanguageSwitcher
                    currentLocale={locale}
                    label={dictionary.brand.switcherLabel}
                    shortLabel={dictionary.brand.switcherShortLabel}
                    alternateLinks={alternateLinks}
                />
            </footer>
        </div>
        <script is:inline set:html={footerDockScript} />
    </body>
</html>
